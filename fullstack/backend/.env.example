APP_ENV=development
APP_PORT=8080
DB_HOST=mysql
DB_PORT=3306
DB_NAME=pharma_platform
DB_USER=pharma_user
DB_PASSWORD=replace_with_strong_db_password
JWT_SECRET=replace_with_long_random_jwt_secret_min_24_chars
JWT_EXP_HOURS=8
APP_ENCRYPTION_KEY=replace_with_strong_encryption_key_min_16_chars
UPLOAD_DIR=storage/uploads
UPLOAD_TMP_DIR=storage/tmp
MAX_UPLOAD_MB=20
RATE_LIMIT_RPM=240
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
